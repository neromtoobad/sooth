# copy to .env and fill in — .env is gitignored, never commit real values

# cspr.cloud api key (console.cspr.cloud) — REST/streaming + x402 facilitator
CSPR_CLOUD_API_KEY=

# casper network
CASPER_NETWORK=casper-test
CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc

# anthropic api key — vibes llm trader only
ANTHROPIC_API_KEY=

# x402 pricing (CSPR per call)
X402_FEED_PRICE=0.5
X402_ORACLE_PRICE=1

# sooth deployment (filled by scripts/deploy.ts — see deployments.json)
SUSD_PACKAGE_HASH=
SUSD_NAME="Sooth USD"
SUSD_SYMBOL=sUSD
FACILITATOR_URL=http://localhost:4022
